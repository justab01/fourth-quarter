{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "while true; do NODE_ENV=development NODE_OPTIONS=--max-old-space-size=256 tsx ./src/index.ts; echo '[api-server] crashed, restarting in 2s...'; sleep 2; done",
    "build": "tsx ./build.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@workspace/db": "workspace:*",
    "@workspace/api-zod": "workspace:*",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "pino": "^9",
    "pino-http": "^10",
    "openai": "^4.77.0"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/express": "^5.0.6",
    "@types/cors": "^2.8.19",
    "@types/cookie-parser": "^1.4.10",
    "esbuild": "^0.27.3",
    "pino-pretty": "^13",
    "tsx": "catalog:"
  }
}
